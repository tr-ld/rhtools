@using rhdata.Rules
@using RHWebFront.Services
@using RHWebFront.Services.RuleDisplay
@inject RuleEditorStateService EditorState

<article class="rule-card-horizontal @(HasPendingChanges ? "has-pending-changes" : "")">
    <div class="rule-card-body-horizontal">
        <div class="rule-active-toggle">
            <label class="toggle-switch">
                <input type="checkbox" checked="@DisplayRule.IsActive" 
                       @onchange="(e) => UpdateField(r => r.IsActive = (bool)e.Value)" />
                <span class="toggle-slider @(DisplayRule.IsActive ? "is-active" : "is-inactive")"></span>
            </label>
        </div>
        
        @if (DisplayRule.Trigger?.TriggerTemplate is not null && DisplayRule.Action?.ActionTemplate is not null && _composition is not null)
        {
            //trigger prompt
            @if (!string.IsNullOrEmpty(_composition.TriggerPrompt.StaticText)) { <span class="rule-text">@_composition.TriggerPrompt.StaticText</span> }
            <select class="field-select" value="@DisplayRule.Trigger.TriggerTemplateId" 
                    @onchange="(e) => UpdateTriggerTemplate(int.Parse(e.Value.ToString()))">
                @foreach (var template in TriggerTemplates) { <option value="@template.Id">@template.Name</option> }
            </select>
            <input type="text" class="field-input" value="@Compositor.FormatValue(DisplayRule.Trigger.Value, _composition.TriggerPrompt.ConfigFormatType)" 
                   @onchange="(e) => UpdateTriggerValue(e.Value.ToString())" />
            
            //action periodicity prompt
            @if (!string.IsNullOrEmpty(_composition.PeriodicityPrompt.StaticText)) { <span class="rule-text">@_composition.PeriodicityPrompt.StaticText</span> }
            <input type="number" class="field-input" value="@DisplayRule.Periodicity.Value" 
                   @onchange="(e) => UpdateField(r => r.Periodicity.Value = int.Parse(e.Value.ToString()))" />
            <select class="field-select" value="@DisplayRule.Periodicity.PeriodicityTemplateId" 
                    @onchange="(e) => UpdatePeriodicityTemplate(int.Parse(e.Value.ToString()))">
                @foreach (var template in PeriodicityTemplates) { <option value="@template.Id">@template.Name</option> }
            </select>
            
            //action prompt
            @if (!string.IsNullOrEmpty(_composition.ActionPrompt.StaticText)) { <span class="rule-text">@_composition.ActionPrompt.StaticText</span> }
            <select class="field-select" value="@DisplayRule.Action.ActionTemplateId" 
                    @onchange="(e) => UpdateActionTemplate(int.Parse(e.Value.ToString()))">
                @foreach (var template in ActionTemplates) { <option value="@template.Id">@template.Name</option> }
            </select>
            @if (!string.IsNullOrEmpty(_composition.ActionPrompt.TrailingText)) { <span class="rule-text">@_composition.ActionPrompt.TrailingText</span> }
            
            //amount prompt
            <input type="text" class="field-input" value="@Compositor.FormatValue(DisplayRule.Amount.Value, _composition.AmountPrompt.ConfigFormatType)" 
                   @onchange="(e) => UpdateAmountValue(e.Value.ToString())" />
            <select class="field-select" value="@DisplayRule.Amount.AmountTemplateId" 
                    @onchange="(e) => UpdateAmountTemplate(int.Parse(e.Value.ToString()))">
                @foreach (var template in AmountTemplates) { <option value="@template.Id">@template.Name</option> }
            </select>
            
            //price prompt
            @if (!string.IsNullOrEmpty(_composition.PricePrompt.StaticText)) { <span class="rule-text">@_composition.PricePrompt.StaticText</span> }
            @if (_composition.PricePrompt.ShowDropdown)
            {
                <select class="field-select" value="@DisplayRule.Price.PriceTemplateId" 
                        @onchange="(e) => UpdatePriceTemplate(int.Parse(e.Value.ToString()))">
                    @foreach (var template in PriceTemplates) { <option value="@template.Id">@template.Name</option> }
                </select>
            }
            @if (_composition.PricePrompt.ShowConfig)
            {
                <input type="text" class="field-input" value="@Compositor.FormatValue(DisplayRule.Price.Value, _composition.PricePrompt.ConfigFormatType)" 
                       @onchange="(e) => UpdatePriceValue(e.Value.ToString())" />
            }
            @if (!string.IsNullOrEmpty(_composition.PricePrompt.TrailingText)) { <span class="rule-text">@_composition.PricePrompt.TrailingText</span> }
        }
        else { <div class="incomplete-rule">Incomplete rule configuration</div> }
        
        @if (HasPendingChanges)
        {
            <button class="undo-btn" @onclick="Undo" title="Undo changes">
                <span class="undo-icon" alt="Undo"></span>
            </button>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired] public Rule OriginalRule { get; set; }
    [Parameter, EditorRequired] public RuleDisplayCompositor Compositor { get; set; }
    [Parameter, EditorRequired] public List<TriggerTemplate> TriggerTemplates { get; set; }
    [Parameter, EditorRequired] public List<ActionTemplate> ActionTemplates { get; set; }
    [Parameter, EditorRequired] public List<PeriodicityTemplate> PeriodicityTemplates { get; set; }
    [Parameter, EditorRequired] public List<AmountTemplate> AmountTemplates { get; set; }
    [Parameter, EditorRequired] public List<PriceTemplate> PriceTemplates { get; set; }
    
    private RuleComposition _composition;
    private bool HasPendingChanges => EditorState.HasPendingChanges(OriginalRule.Id);
    private Rule DisplayRule => EditorState.GetPendingRule(OriginalRule.Id) ?? OriginalRule;

    protected override void OnParametersSet() { RecomposeUI(); }

    private void RecomposeUI() { _composition = Compositor.ComposeRule(DisplayRule); }

    private void UpdateField(Action<Rule> updateAction)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        updateAction(pendingRule);
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
    }

    private void UpdateTriggerTemplate(int templateId)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        var template = TriggerTemplates.First(t => t.Id == templateId);
        pendingRule.Trigger.TriggerTemplateId = templateId;
        pendingRule.Trigger.TriggerTemplate = template;
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
        RecomposeUI();
    }

    private void UpdateTriggerValue(string input)
    {
        if (Compositor.ValidateValue(input, _composition.TriggerPrompt.ConfigFormatType, out var value)) UpdateField(r => r.Trigger.Value = value);
    }

    private void UpdateActionTemplate(int templateId)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        var template = ActionTemplates.First(t => t.Id == templateId);
        
        pendingRule.Action.ActionTemplateId = templateId;
        pendingRule.Action.ActionTemplate = template;
        
        if (templateId is RuleTemplateConstants.ACTION_MARKET_SELL_ID or RuleTemplateConstants.ACTION_MARKET_BUY_ID)
        {
            var flatPriceTemplate = PriceTemplates.First(p => p.Id == RuleTemplateConstants.PRICE_FLAT_ID);
            pendingRule.Price.PriceTemplateId = RuleTemplateConstants.PRICE_FLAT_ID;
            pendingRule.Price.PriceTemplate = flatPriceTemplate;
            pendingRule.Price.Value = 0;
        }
        
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
        RecomposeUI();
    }

    private void UpdatePeriodicityTemplate(int templateId)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        var template = PeriodicityTemplates.First(t => t.Id == templateId);
        pendingRule.Periodicity.PeriodicityTemplateId = templateId;
        pendingRule.Periodicity.PeriodicityTemplate = template;
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
        RecomposeUI();
    }

    private void UpdateAmountTemplate(int templateId)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        var template = AmountTemplates.First(t => t.Id == templateId);
        pendingRule.Amount.AmountTemplateId = templateId;
        pendingRule.Amount.AmountTemplate = template;
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
        RecomposeUI();
    }

    private void UpdateAmountValue(string input)
    {
        if (Compositor.ValidateValue(input, _composition.AmountPrompt.ConfigFormatType, out var value)) UpdateField(r => r.Amount.Value = value);
    }

    private void UpdatePriceTemplate(int templateId)
    {
        var pendingRule = EditorState.GetPendingRule(OriginalRule.Id) ?? (Rule)OriginalRule.Clone();
        var template = PriceTemplates.First(t => t.Id == templateId);
        pendingRule.Price.PriceTemplateId = templateId;
        pendingRule.Price.PriceTemplate = template;
        EditorState.TrackChange(OriginalRule.Id, pendingRule);
        CheckIfBackToOriginal();
        RecomposeUI();
    }

    private void UpdatePriceValue(string input)
    {
        if (Compositor.ValidateValue(input, _composition.PricePrompt.ConfigFormatType, out var value)) UpdateField(r => r.Price.Value = value);
    }

    private void CheckIfBackToOriginal()
    {
        if (OriginalRule.Id < 0) return;
        
        if (EditorState.GetPendingRule(OriginalRule.Id) is { } pendingRule && OriginalRule.Equals(pendingRule)) EditorState.UndoChanges(OriginalRule.Id);
    }

    public void Undo()
    {
        EditorState.UndoChanges(OriginalRule.Id);
        RecomposeUI();
    }
}