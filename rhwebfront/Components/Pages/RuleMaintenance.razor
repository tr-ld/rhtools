@page "/rules"
@rendermode InteractiveServer
@using abstractions.Services
@using RHWebFront.Config
@using RHWebFront.Extensions
@using Microsoft.Extensions.Options
@using rhdata
@using rhdata.Rules
@inject IRhAssetManager AssetManager
@inject IRuleManager RuleManager
@inject NavigationManager Navigation
@inject IOptionsSnapshot<AppConfig> AppConfig
@inject ISelectedSymbolManager SymbolManager

<div class="page-header">
    <h3>@(!string.IsNullOrEmpty(SymbolManager.SelectedSymbol) ? $"{SymbolManager.SelectedSymbol} Rules" : "Symbol Rules")</h3>
    <button class="change-symbol-btn" @onclick="ShowSymbolSelector" title="Change symbol" disabled="@(string.IsNullOrEmpty(SymbolManager.SelectedSymbol))">
        <img src="/icons/crypto-symbol.svg" alt="Change symbol" class="crypto-icon" />
    </button>
</div>

@if (SymbolManager.ShowSymbolSelector)
{
    <SymbolSelector TradingPairs="_tradingPairs" RuleSets="_ruleSets" OnSymbolSelected="HandleSymbolSelected" />
}

@if (!string.IsNullOrEmpty(_validationError)) { <div class="validation-error">@_validationError</div> }

@if (!string.IsNullOrEmpty(SymbolManager.SelectedSymbol))
{
    <div class="rules-section">
        @if (_activeRuleSet is null)
        {
            <div class="loading-state">
                <p>Loading rules...</p>
            </div>
        }
        else
        {
            <div class="rules-container">
                <div class="rule-list-section">
                    <div class="position-warning">&#9888; Position management placeholder - rules ordered by creation</div>
                    
                    @if (_activeRuleSet.Rules.Any())
                    {
                        <div class="rule-list">
                            @foreach (var rule in _activeRuleSet.Rules.OrderBy(r => r.Position?.Position ?? 0))
                            {
                                var isSelected = _editingRule is not null && _editingRule.Id == rule.Id;
                                
                                <article class="rule-card @(isSelected ? "selected" : "")" @onclick="() => SelectRule(rule)">
                                    <header class="rule-card-header">
                                        <div class="rule-position">Position @(rule.Position?.Position ?? 0)</div>
                                        <div class="rule-active-toggle">
                                            <input type="checkbox" id="active-@rule.Id" checked="@rule.IsActive" @onclick="() => ToggleRuleActive(rule)" @onclick:stopPropagation="true" />
                                            <label for="active-@rule.Id">@(rule.IsActive ? "Active" : "Inactive")</label>
                                        </div>
                                    </header>
                                    <div class="rule-card-body">
                                        @if (rule.Trigger?.TriggerTemplate is not null && rule.Action?.ActionTemplate is not null)
                                        {
                                            <div class="rule-detail">
                                                <span class="label">Trigger:</span>
                                                <span class="value">@rule.Trigger.TriggerTemplate.Name (@rule.Trigger.Value)</span>
                                            </div>
                                            <div class="rule-detail">
                                                <span class="label">Action:</span>
                                                <span class="value">@rule.Action.ActionTemplate.Name (@rule.Action.Value)</span>
                                            </div>
                                            <div class="rule-detail">
                                                <span class="label">Precision:</span>
                                                <span class="value">@(rule.Precision?.PrecisionTemplate?.Name ?? "N/A") (@(rule.Precision?.Value ?? 0))</span>
                                            </div>
                                            <div class="rule-detail">
                                                <span class="label">Amount:</span>
                                                <span class="value">@(rule.Amount?.AmountTemplate?.Name ?? "N/A") (@(rule.Amount?.Value ?? 0))</span>
                                            </div>
                                        }
                                        else { <div class="incomplete-rule">Incomplete rule configuration</div> }
                                    </div>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="no-rules">
                            <p>No rules defined.</p>
                        </div>
                    }
                    
                    <div class="rule-list-actions">
                        <button class="create-rule-btn" @onclick="CreateNewRule">+ Create New Rule</button>
                    </div>
                </div>

                <div class="rule-edit-section">
                    <RuleEditor EditingRule="_editingRule" IsNewRule="_isNewRule" OnSave="HandleSaveRule" OnCancel="CancelEdit" />
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="rules-section disabled">
        <p>Select a symbol above to manage rules</p>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "symbol")]
    private string QuerySymbol { get; set; }
    
    [SupplyParameterFromQuery(Name = "assetCode")]
    private string QueryAssetCode { get; set; }

    private List<RHTradingPair> _tradingPairs;
    private List<RuleSet> _ruleSets;
    private string _validationError = null;

    private RuleSet _activeRuleSet;
    private Rule _editingRule;
    private bool _isNewRule;

    protected override async Task OnInitializedAsync()
    {
        _tradingPairs = (await AssetManager.GetTradingPairs()).ForTradeCurrency(AppConfig.Value.TradeCurrency).ToList();
        _ruleSets = await RuleManager.GetRuleSetsForTradeCurrencyAsync();
        
        ValidateResolvedSymbol();
    }

    private string _resolvedSymbol = null;
    protected override void OnParametersSet()
    {
        // Construct/resolve the symbol from query parameters
        if (!string.IsNullOrEmpty(QuerySymbol)) { _resolvedSymbol = QuerySymbol; }
        else if (!string.IsNullOrEmpty(QueryAssetCode))
        {
            _resolvedSymbol = $"{QueryAssetCode}-{AppConfig.Value.TradeCurrency}";
            Navigation.NavigateTo($"/rules?symbol={_resolvedSymbol}", replace: true);
        }
        else { _resolvedSymbol = null; }

        // If data is already loaded (subsequent parameter changes), validate immediately
        if (_tradingPairs is not null) { ValidateResolvedSymbol(); }
    }

    private async void ValidateResolvedSymbol()
    {
        if (string.IsNullOrEmpty(_resolvedSymbol))
        {
            if (string.IsNullOrEmpty(SymbolManager.SelectedSymbol)) _validationError = null;
            return;
        }

        if (SymbolExists(_resolvedSymbol))
        {
            SymbolManager.SelectedSymbol = _resolvedSymbol;
            SymbolManager.ShowSymbolSelector = false;
            _validationError = null;
            await LoadRuleSetForSymbol(_resolvedSymbol);
        }
        else
        {
            SymbolManager.ClearSelection();
            _validationError = $"The symbol '{_resolvedSymbol}' was not found. Please select from the list.";
        }
    }

    private bool SymbolExists(string symbol) => _tradingPairs?.Any(p => p.Symbol == symbol) ?? false;

    private async Task HandleSymbolSelected(RHTradingPair pair)
    {
        _validationError = null;

        if (SymbolManager.SelectedSymbol == pair.Symbol) { SymbolManager.ShowSymbolSelector = false; return; }

        SymbolManager.SelectedSymbol = pair.Symbol;
        SymbolManager.ShowSymbolSelector = false;
        Navigation.NavigateTo($"/rules?symbol={pair.Symbol}", replace: true);
        
        await LoadRuleSetForSymbol(pair.Symbol);
    }

    private async Task LoadRuleSetForSymbol(string symbol)
    {
        _activeRuleSet = await RuleManager.GetRuleSetBySymbolAsync(symbol) ?? new RuleSet { Symbol = symbol };

        CancelEdit();
        StateHasChanged();
    }

    private void CreateNewRule()
    {
        var nextPosition = _activeRuleSet.Rules.Any() ? _activeRuleSet.Rules.Max(r => r.Position?.Position ?? 0) + 1 : 1;
        
        _editingRule = new Rule
        {
            RuleSetId = _activeRuleSet.Id,
            IsActive = true,
            Position = new RuleOrderPosition { Position = nextPosition }
        };
        
        _isNewRule = true;
    }

    private void SelectRule(Rule rule)
    {
        _editingRule = rule;
        _isNewRule = false;
    }

    private void ToggleRuleActive(Rule rule)
    {
        rule.IsActive = !rule.IsActive;
    }

    private async Task HandleSaveRule((Rule rule, RuleTrigger trigger, RuleAction action, RulePrecision precision, RuleAmount amount) data)
    {
        data.rule.Trigger = data.trigger;
        data.rule.Action = data.action;
        data.rule.Precision = data.precision;
        data.rule.Amount = data.amount;

        if (_isNewRule)
        {
            if (0 == _activeRuleSet.Id)
            {
                _activeRuleSet = await RuleManager.SaveRuleSetAsync(_activeRuleSet);
            }
            
            data.rule.RuleSetId = _activeRuleSet.Id;
            _activeRuleSet.Rules.Add(data.rule);
        }

        await RuleManager.SaveRuleAsync(data.rule);
        
        await LoadRuleSetForSymbol(_activeRuleSet.Symbol);
    }

    private void CancelEdit()
    {
        _editingRule = null;
        _isNewRule = false;
    }

    private void ShowSymbolSelector()
    {
        SymbolManager.ShowSymbolSelector = !SymbolManager.ShowSymbolSelector;
    }
}
